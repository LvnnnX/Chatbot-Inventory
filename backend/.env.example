# DeepSeek (OpenAI-compatible API)
# Ambil API key di https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_api_key_here

# Base URL default DeepSeek. Biarin kalau pakai DeepSeek resmi.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Model string. Pakai keluarga deepseek-chat (mendukung function calling).
# Ganti sesuai nama model yang kamu pakai. Model reasoner TIDAK mendukung tools.
DEEPSEEK_MODEL=deepseek-chat

# Port backend lokal
PORT=3001
